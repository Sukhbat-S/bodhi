# ============================================================
# BODHI — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Required ---

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# PostgreSQL with pgvector extension (Supabase recommended)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres

# Voyage AI (embeddings for semantic memory search)
# Get a key at: https://dash.voyageai.com/
VOYAGE_API_KEY=

# --- Server ---

PORT=4000
NODE_ENV=development
BODHI_OWNER_NAME=User
TIMEZONE=Asia/Ulaanbaatar

# Persona file (optional — customize BODHI's personality)
# PERSONA_PATH=./configs/persona/bodhi.md

# --- Optional Integrations ---
# Enable as many or as few as you want. BODHI works with just the required vars above.

# Google (Gmail + Calendar context)
# Create OAuth credentials at: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/oauth/callback

# Notion (workspace tasks + sessions)
# Create an integration at: https://www.notion.so/my-integrations
# NOTION_API_KEY=
# NOTION_TASKS_DB=
# NOTION_SESSIONS_DB=

# GitHub (commit, PR, issue tracking)
# Generate a token at: https://github.com/settings/tokens
# GITHUB_TOKEN=
# GITHUB_REPOS=owner/repo1,owner/repo2

# Vercel (deployment tracking)
# Generate a token at: https://vercel.com/account/tokens
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Supabase Awareness (project health monitoring)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# Meta / Social (Facebook + Instagram posting via Graph API)
# META_PAGE_ID=
# META_PAGE_ACCESS_TOKEN=
# META_INSTAGRAM_ACCOUNT_ID=

# Groq (voice transcription via Whisper — for Telegram voice journals)
# Get a key at: https://console.groq.com/
# GROQ_API_KEY=

# Web Push Notifications (PWA push to dashboard)
# Generate VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# PUBLIC_URL=https://bodhi.yourdomain.com

# Claude Code CLI auth (for Docker/VPS — pass OAuth token via env)
# CLAUDE_CODE_OAUTH_TOKEN=

# --- Deployment ---

# BODHI_PROJECT_DIR=/app
# CORS_ORIGINS=https://bodhi.yourdomain.com
