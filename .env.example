# ============================================================
# BODHI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Required ---

# Anthropic (Claude Code CLI must be installed and authed separately)
ANTHROPIC_API_KEY=sk-ant-...

# Owner name (used in prompts and briefings)
BODHI_OWNER_NAME=YourName

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id

# Database (Supabase PostgreSQL with pgvector extension)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require

# Memory Embeddings (Voyage AI)
VOYAGE_API_KEY=pa-...

# --- Optional Integrations ---

# Google OAuth2 (Gmail + Calendar, read-only)
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Notion (workspace knowledge)
NOTION_API_KEY=ntn_...
NOTION_SESSIONS_DB=your-database-id

# GitHub (activity tracking)
GITHUB_TOKEN=ghp_...
GITHUB_REPOS=owner/repo1,owner/repo2

# Vercel (deployment tracking)
VERCEL_TOKEN=...
VERCEL_TEAM_ID=...

# Supabase Management API (project health monitoring)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=your-project-ref

# Groq (Whisper transcription for voice messages)
GROQ_API_KEY=gsk_...

# --- Deployment (VPS) ---

VPS_HOST=your-vps-ip
VPS_USER=ubuntu
SSH_KEY=/path/to/your/ssh-key

# --- Server ---

PORT=4000
NODE_ENV=development

# --- Advanced ---

# Timezone for scheduler (cron briefings)
BODHI_TIMEZONE=UTC

# External project directory (for multi-project support)
# BODHI_PROJECT_DIR=/path/to/your/other/project
# BODHI_PROJECT_NAME=My Project
# BODHI_PROJECT_DESCRIPTION=Description of the project

# Additional projects as JSON (for knowledge provider)
# BODHI_EXTRA_PROJECTS='[{"name":"myproject","path":"/path/to/project","keywords":["keyword1","keyword2"]}]'
